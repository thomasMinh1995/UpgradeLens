{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/thomasMinh1995/UpgradeLens/main/schemas/project-manifest.schema.json",
  "title": "UpgradeLens Project Manifest",
  "description": "Portable output produced by UpgradeLens project discovery.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "generatedAt",
    "generator",
    "repository",
    "summary",
    "projects",
    "warnings"
  ],
  "properties": {
    "schemaVersion": { "const": "1.0.0" },
    "generatedAt": { "type": "string", "format": "date-time" },
    "generator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "const": "UpgradeLens" },
        "version": { "type": "string" }
      }
    },
    "repository": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "root"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "root": { "const": "." },
        "vcs": {
          "type": "object",
          "additionalProperties": false,
          "required": ["type"],
          "properties": {
            "type": { "const": "git" },
            "branch": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["projectCount", "ecosystems", "workspaceCount"],
      "properties": {
        "projectCount": { "type": "integer", "minimum": 0 },
        "ecosystems": {
          "type": "object",
          "additionalProperties": { "type": "integer", "minimum": 1 }
        },
        "workspaceCount": { "type": "integer", "minimum": 0 }
      }
    },
    "projects": {
      "type": "array",
      "items": { "$ref": "#/$defs/project" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/warning" }
    }
  },
  "$defs": {
    "packageManager": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "path", "ecosystem", "languages", "manifests", "metadata"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "ecosystem": {
          "enum": ["al", "dotnet", "go", "java", "node", "php", "python", "ruby", "rust"]
        },
        "languages": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "manifests": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string", "minLength": 1 }
        },
        "version": { "type": "string" },
        "private": { "type": "boolean" },
        "packageManager": { "$ref": "#/$defs/packageManager" },
        "workspace": {
          "type": "object",
          "additionalProperties": false,
          "required": ["root", "role"],
          "properties": {
            "root": { "type": "string", "minLength": 1 },
            "role": { "enum": ["root", "member"] }
          }
        },
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": ["dependencyCount"],
          "properties": {
            "dependencyCount": { "type": "integer", "minimum": 0 }
          }
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "path", "message"],
      "properties": {
        "code": {
          "enum": ["DIRECTORY_UNREADABLE", "MANIFEST_INVALID", "MANIFEST_UNREADABLE"]
        },
        "path": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
