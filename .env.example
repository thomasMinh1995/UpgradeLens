# OpenAI-compatible runtime
UPGRADELENS_AI_PROVIDER=openai-compatible

# OpenRouter Chat Completions endpoint
UPGRADELENS_AI_ENDPOINT=https://openrouter.ai/api/v1/chat/completions

# Replace with one exact OpenRouter model slug.
# Do not use openrouter/auto or openrouter/free for this validation.
UPGRADELENS_AI_MODEL=<exact-openrouter-model-slug>

# Local validation timeout.
UPGRADELENS_AI_TIMEOUT_MS=180000

# OpenRouter uses Bearer authentication.
# Put the real value only in your local .env file.
UPGRADELENS_AI_AUTHORIZATION=Bearer <OPENROUTER_API_KEY>
