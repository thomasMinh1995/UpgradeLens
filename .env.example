# OpenAI-compatible runtime
DEPVERDICT_AI_PROVIDER=openai-compatible

# OpenRouter Chat Completions endpoint
DEPVERDICT_AI_ENDPOINT=https://openrouter.ai/api/v1/chat/completions

# Replace with one exact OpenRouter model slug.
# Do not use openrouter/auto or openrouter/free for this validation.
DEPVERDICT_AI_MODEL=<exact-openrouter-model-slug>

# Local validation timeout.
DEPVERDICT_AI_TIMEOUT_MS=180000

# OpenRouter uses Bearer authentication.
# Put the real value only in your local .env file.
DEPVERDICT_AI_AUTHORIZATION=Bearer <OPENROUTER_API_KEY>

# UPGRADELENS_* remains a deprecated fallback during the 0.6.x preview window.
# Do not define both prefixes; DEPVERDICT_* wins conflicts.
